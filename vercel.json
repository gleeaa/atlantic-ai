{
  "version": 2,
  "functions": {
    "api/chat.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat"
    },
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    },
    {
      "source": "/",
      "destination": "/client/index.html"
    }
  ]
}